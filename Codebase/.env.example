# Environment Variables

# Next.js
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Analytics (Optional)
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=

# Contact Form (Optional - currently simulates API call)
# RESEND_API_KEY=re_your_api_key_here
# CONTACT_EMAIL=hello@deltax.dev

# Database (Optional - for future features)
# DATABASE_URL=postgresql://user:password@localhost:5432/deltax
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your_anon_key_here

# Auth (Optional - for future features)
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=your_secret_here_at_least_32_chars
